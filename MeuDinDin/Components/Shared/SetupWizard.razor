@inject IFinanceHub Hub

<section class="hero">
    <div>
        <p class="eyebrow">Configuracao inicial</p>
        <h1>Vincule seu login a uma familia.</h1>
        <p class="hero__text">Crie uma nova base para sua casa ou use o codigo de uma familia existente para compartilhar os mesmos dados com outra pessoa.</p>
    </div>
    <div class="hero__summary">
        <div class="hero__summary-label">Conta logada</div>
        <div class="hero__summary-value">@CurrentUserName</div>
        <div class="hero__summary-helper">@CurrentUserEmail</div>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Error))
{
    <div class="form-alert form-alert--danger">@Error</div>
}

<section class="content-grid">
    <article class="panel panel--wide">
        <div class="panel__header">
            <h2>Criar nova familia</h2>
            <span class="pill">Novo codigo</span>
        </div>

        <form method="post" action="/auth/family/create" class="form-grid">
            <AntiforgeryToken />

            <label class="field field--full">
                <span>Nome da familia</span>
                <input type="text" name="familyName" required />
            </label>

            <label class="field field--full">
                <span>Nome que aparecera nos lancamentos</span>
                <input type="text" name="memberName" value="@CurrentUserName" required />
            </label>

            <button type="submit" class="button button--primary">Criar familia</button>
        </form>
    </article>

    <article class="panel">
        <div class="panel__header">
            <h2>Entrar em familia existente</h2>
            <span class="pill">Mesmo banco</span>
        </div>

        <form method="post" action="/auth/family/join" class="form-grid">
            <AntiforgeryToken />

            <label class="field field--full">
                <span>Codigo da familia</span>
                <input type="text" name="accessCode" maxlength="8" autocomplete="one-time-code" required />
            </label>

            <label class="field field--full">
                <span>Nome que aparecera nos lancamentos</span>
                <input type="text" name="memberName" value="@CurrentUserName" required />
            </label>

            <button type="submit" class="button button--ghost">Entrar com codigo</button>
        </form>
    </article>
</section>

@code {
    [SupplyParameterFromQuery(Name = "erro")]
    public string? Error { get; set; }

    private string CurrentUserName => Hub.CurrentUser?.DisplayName ?? "Usuario";

    private string CurrentUserEmail => Hub.CurrentUser?.Email ?? string.Empty;
}
